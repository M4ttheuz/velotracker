@{
    ViewData["Title"] = "Import Route";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="text-center">Import Route (GPX/TCX)</h2>
            <form asp-action="Import" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label for="routeFile">Route File</label>
                    <input type="file" id="routeFile" name="routeFile" class="form-control" accept=".gpx,.tcx" required />
                    <small class="form-text text-muted">Select a GPX or TCX file to import.</small>
                </div>

                <div class="form-group mb-3">
                    <label for="title">Title</label>
                    <input type="text" id="title" name="title" class="form-control" required placeholder="My Awesome Ride" />
                </div>

                <div class="form-group mb-3">
                    <label for="difficulty">Difficulty</label>
                    <select id="difficulty" name="difficulty" class="form-control">
                        <option value="Easy">Easy</option>
                        <option value="Medium" selected>Medium</option>
                        <option value="Hard">Hard</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary w-100">Import Route</button>
            </form>
        </div>
    </div>
</div>
