@model velotracker.Models.Trail
@{
    ViewData["Title"] = Model.Title;
}

<div class="row mb-4">
    <div class="col-md-8">
        <h2>@Model.Title</h2>
        <p class="text-muted">Dodano przez: @(Model.User?.Username ?? "Nieznany") w dniu @Model.CreatedAt.ToString("g")</p>
        <p>@Model.Description</p>
    </div>
    <div class="col-md-4 text-end">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Powrót do listy</a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header">
                Szczegóły Trasy
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item"><strong>Dystans:</strong> @Model.DistanceKm.ToString("0.00") km</li>
                <li class="list-group-item"><strong>Przewyższenia:</strong> @Model.ElevationGainM m</li>
                <li class="list-group-item"><strong>Trudność:</strong> @Model.Difficulty</li>
                <li class="list-group-item"><strong>Status:</strong> @Model.VerificationStatus</li>
            </ul>
        </div>
    </div>
    <div class="col-md-8">
        <div id="map" style="height: 500px; width: 100%; border-radius: 8px; margin-bottom: 20px;"></div>
        <div class="card">
            <div class="card-header">
                Profil wysokościowy
            </div>
            <div class="card-body">
                <canvas id="elevationChart" style="width:100%; height:250px;"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var map = L.map('map').setView([@Model.StartLatitude.ToString(System.Globalization.CultureInfo.InvariantCulture), @Model.StartLongitude.ToString(System.Globalization.CultureInfo.InvariantCulture)], 13);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '© OpenStreetMap'
            }).addTo(map);

            var routePoints = [
                @foreach (var point in Model.TrailPoints.OrderBy(p => p.SequenceOrder))
                {
                    @Html.Raw($"[{point.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture)}, {point.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture)}],")
                }
            ];

            if (routePoints.length > 0) {
                var polyline = L.polyline(routePoints, { color: 'blue', weight: 5 }).addTo(map);

                map.fitBounds(polyline.getBounds());

                L.marker(routePoints[0]).addTo(map).bindPopup("Start");

                L.marker(routePoints[routePoints.length - 1]).addTo(map).bindPopup("Meta");

                var elevations = [
                    @foreach (var point in Model.TrailPoints.OrderBy(p => p.SequenceOrder))
                    {
                        @Html.Raw($"{(point.ElevationM.HasValue ? point.ElevationM.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null")},")
                    }
                ];

                var labels = Array.from({length: elevations.length}, (_, i) => i + 1);

                var ctx = document.getElementById('elevationChart').getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Wysokość (m n.p.m.)',
                            data: elevations,
                            borderColor: 'rgb(75, 192, 192)',
                            backgroundColor: 'rgba(75, 192, 192, 0.2)',
                            tension: 0.1,
                            fill: true,
                            pointRadius: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            x: {
                                display: false
                            },
                            y: {
                                beginAtZero: false,
                                title: {
                                    display: true,
                                    text: 'Wysokość (m)'
                                }
                            }
                        },
                        plugins: {
                            legend: {
                                display: false
                            },
                            tooltip: {
                                callbacks: {
                                    title: function() { return ''; }
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
}