@model IEnumerable<velotracker.Models.Trail>
@{
    ViewData["Title"] = "Strona Główna";
}

<div class="text-center mb-4">
    <h1 class="display-4">Velotracker</h1>
    <p>Oto lista ostatnio wgranych tras.</p>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form asp-controller="Home" asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label for="searchString" class="form-label">Tytuł / Opis (lokalizacja)</label>
                <input type="text" class="form-control" id="searchString" name="searchString" value="@ViewData["SearchString"]" placeholder="Czego szukasz?">
            </div>

            <div class="col-md-2">
                <label class="form-label">Dystans (km)</label>
                <div class="input-group">
                    <input type="number" step="0.1" min="0" class="form-control" name="minDistance" placeholder="Min" value="@ViewData["MinDistance"]" list="minDistanceHints">
                    <span class="input-group-text">-</span>
                    <input type="number" step="0.1" min="0" class="form-control" name="maxDistance" placeholder="Max" value="@ViewData["MaxDistance"]" list="maxDistanceHints">
                </div>
            </div>

            <div class="col-md-2">
                <label class="form-label">Przewyższenia (m)</label>
                <div class="input-group">
                    <input type="number" min="0" class="form-control" name="minElevation" placeholder="Min" value="@ViewData["MinElevation"]" list="elevationHints">
                    <span class="input-group-text">-</span>
                    <input type="number" min="0" class="form-control" name="maxElevation" placeholder="Max" value="@ViewData["MaxElevation"]" list="elevationHints">
                </div>
            </div>

            <datalist id="minDistanceHints">
                <option value="0" />
                <option value="20" />
                <option value="50" />
            </datalist>

            <datalist id="maxDistanceHints">
                <option value="50" />
                <option value="100" />
                <option value="150" />
                <option value="200" />
            </datalist>

            <datalist id="elevationHints">
                <option value="100" />
                <option value="300" />
                <option value="500" />
                <option value="1000" />
                <option value="1500" />
            </datalist>

            <div class="col-md-2">
                <label for="trailType" class="form-label">Rodzaj trasy</label>
                <select id="trailType" name="trailType" class="form-select">
                    <option value="">Wszystkie</option>
                    @if (ViewData["TrailType"]?.ToString() == "Szosowa")
                    {
                        <option value="Szosowa" selected>Szosowa</option>
                    }
                    else
                    {
                        <option value="Szosowa">Szosowa</option>
                    }
                    @if (ViewData["TrailType"]?.ToString() == "MTB")
                    {
                        <option value="MTB" selected>MTB</option>
                    }
                    else
                    {
                        <option value="MTB">MTB</option>
                    }
                    @if (ViewData["TrailType"]?.ToString() == "Gravel")
                    {
                        <option value="Gravel" selected>Gravel</option>
                    }
                    else
                    {
                        <option value="Gravel">Gravel</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100 mb-2">Filtruj</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Wyczyść</a>
            </div>
        </form>
    </div>
</div>

<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var trail in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@trail.Title</h5>
                        <h6 class="card-subtitle mb-2 text-muted">Dystans: @trail.DistanceKm.ToString("0.00") km | Przewyższenia: @trail.ElevationGainM m</h6>
                        <p class="card-text">@trail.Description</p>
                        <a asp-controller="Trail" asp-action="Details" asp-route-id="@trail.Id" class="btn btn-primary btn-sm">Szczegóły</a>
                    </div>
                    <div class="card-footer text-muted">
                        Dodano: @trail.CreatedAt.ToString("g")
                        @if (trail.User != null)
                        {
                            <br /><span>Przez: @trail.User.Username</span>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center">
            <p>Brak wgranych tras. Pora dodać pierwszą!</p>
        </div>
    }
</div>
